NEXTAUTH_URL="http://localhost:3000"

# Email notifications
# For local development, leave these empty to use Ethereal (auto-setup, inbox URL printed to console)
# For production, set your SMTP credentials:
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="BridgeIn <noreply@bridgein.app>"
